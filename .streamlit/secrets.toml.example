# Streamlit secrets template for PhDMe.
#
# Local use:
#   1. Copy this file to ".streamlit/secrets.toml" (same folder, drop ".example").
#   2. Fill in your Gemini API key below.
#   The real secrets.toml is git-ignored and must never be committed.
#
# Streamlit Community Cloud:
#   Don't upload secrets.toml. Instead paste these values into
#   App → Settings → Secrets in the Streamlit Cloud dashboard.
#
# Get a Gemini API key: https://aistudio.google.com/apikey

# The app reads the first key it finds (GOOGLE_API_KEY, then GENAI_API_KEY, then GEMINI_API_KEY).
GOOGLE_API_KEY = "your_gemini_api_key_here"
